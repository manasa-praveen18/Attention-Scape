{
  "manifest_version": 3,
  "name": "Attensia",
  "version": "1.0",
  "description": "Privacy-first browsing analytics",
  "permissions": ["tabs", "storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Attensia",
    "default_popup": "popup/popup.html"
  }
}